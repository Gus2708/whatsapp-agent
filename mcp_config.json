{
  "mcpServers": {
    "supabase-serrucho": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-postgres-secure",
        "--access-mode",
        "readonly"
      ],
      "env": {
        "PG_HOST": "aws-0-us-east-1.pooler.supabase.com",
        "PG_PORT": "5432",
        "PG_USER": "serrucho_agent_readonly.rgniqjfooifchyctnbzu",
        "PG_PASSWORD": "${PG_PASSWORD}",
        "PG_DATABASE": "postgres",
        "PG_LOCK_CONNECTION": "true"
      }
    },
    "engram": {
      "command": "engram",
      "args": [
        "mcp"
      ],
      "env": {
        "ENGRAM_DATA_DIR": "/home/node/.engram",
        "ENGRAM_TIMEZONE": "America/Caracas"
      }
    }
  }
}
