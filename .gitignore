# ── Entorno y secretos ──
.env
.env.local
.env.*.local

# ── Dependencias ──
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs (boot, catchup, watchdog, sync, etc.) ──
*.log
logs/

# ── Docker / volúmenes locales ──
.docker/
waha_session_storage/
n8n_local_storage/

# ── QR / imágenes temporales ──
qr_whatsapp.png

# ── Config local de herramientas de desarrollo ──
.mcp.json
.claude/
.atl/
.agents/skills/*/.skill-registry.cache.json

# ── Scratch local desechable ──
#   OJO: 'scratch/' es desechable y se ignora; 'scratch_live/' SÍ se versiona
#   (son los dumps canónicos que verifican los guards de npm test). No ignorar.
scratch/

# ── Backups temporales de los patches (scripts/patch_*.js crean *.bak.js) ──
*.bak.js
*.bak

# ── Archivos del sistema operativo ──
Thumbs.db
Desktop.ini
.DS_Store
