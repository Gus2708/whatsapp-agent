# ═══════════════════════════════════════════════════
# Ferretería El Serrucho — Variables de Entorno
# ═══════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores.

# ── Configuración de ejecución ──
MCP_MODE=stdio
LOG_LEVEL=error
DISABLE_CONSOLE_OUTPUT=true
N8N_MCP_TELEMETRY_DISABLED=true
WEBHOOK_SECURITY_MODE=permissive

# ── n8n ──
N8N_API_URL=http://localhost:5678
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=tu_n8n_api_key_aqui

# ── WAHA (WhatsApp HTTP API) ──
WAHA_DASHBOARD_USERNAME=admin_serrucho
WAHA_DASHBOARD_PASSWORD=cambia_esta_contraseña
WAHA_API_KEY=tu_waha_api_key_aqui

# ── Supabase (Base de Datos) ──
SUPABASE_URL=https://rgniqjfooifchyctnbzu.supabase.co
SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# ── Supabase Postgres (MCP directo — solo lectura) ──
PG_PASSWORD=tu_pg_password_aqui

# ── Engram (Memoria a Largo Plazo) ──
ENGRAM_HOST=host.docker.internal:7437
